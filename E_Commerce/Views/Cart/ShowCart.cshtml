@model List<E_Commerce.Models.CartItemModel>

<style>
    .cart-item {
        border: 1px solid #ccc;
        padding: 10px;
        margin-bottom: 10px;
    }

    .item-image {
        width: auto;
        height: 130px;
    }

    .item-name {
        font-weight: bold;
    }

    .item-price {
        color: green;
        font-weight: bold;
    }

    .item-quantity {
        color: blue;
    }

    .btn-quantity {
        width: 30px;
    }

    .btn-delete {
        margin-top: 10px;
    }
</style>

<div class="container">
    <h1 class="mt-3">Giỏ hàng của bạn</h1>
    @if (Model.Count > 0)
    {
        <div class="row">
            @foreach (var item in Model)
            {
                <div class="col-md-12">
                    <div class="cart-item">
                        <div class="row">
                            <div class="col-md-1 d-flex align-items-center justify-content-cente" style="margin-left: 10px">
                                <input type="checkbox" class="form-check-input" style=" width: 20px; height: 20px;">
                            </div>
                            <div class="col-md-2">
                                <img class="item-image" src="@(item.Picture)" alt="Product 1">
                            </div>
                            <div class="col-md-6">
                                <div class="row">
                                    <div class="col-md-12">
                                        <p class="item-name">@(item.Name)</p>
                                        <p class="item-price .item-quantity">Giá: @item.Price VNĐ </p>
                                    </div>
                                    <div class="col-md-9">
                                        <div class="input-group">
                                            <p class=" item-name .item-quantity mt-3 ">Số lượng: </p>
                                            <input type="number" class=" form-control btn-quantity" style="margin-left:10px" value=@item.Number>
                                        </div>
                                    </div>
                                </div>
                            </div>
                            <div class="col-md-2 d-flex align-items-center justify-content-center">
                                <form method="post" asp-action="DeleteItemCart" asp-route-id="@item.Id.ToString()">
                                    <button type="submit" class="btn btn-danger">Xóa</button>
                                </form>
                            </div>
                        </div>
                    </div>
                </div>

            }
        </div>
        <div class="container mt-3">
            <div class="row">
                <div class="col-md-12 text-right">
                    <button class="btn btn-primary">Mua các mục đã chọn</button>
                </div>
            </div>
        </div>
    }
    else
    {

        <i>(Hiện tại giỏ hàng của bạn đang trống)</i>
    }
</div>
<script>
    // Xử lý sự kiện nút tăng/giảm số lượng
    $(document).on('click', '.btn-plus, .btn-minus', function () {
        const input = $(this).closest('.input-group').find('.btn-quantity');
        const value = parseInt(input.val());

        if ($(this).hasClass('btn-plus')) {
            input.val(value + 1);
        } else if (value > 1) {
            input.val(value - 1);
        }
    });
</script>


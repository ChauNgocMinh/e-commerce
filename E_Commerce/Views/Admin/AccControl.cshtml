@model List<E_Commerce.Areas.Identity.Data.ApplicationUser>

<style>
    td:last-child {
        text-align: center;
    }
</style>

<div class="container">
    <div class="d-flex mt-3 mb-3">
        <a class="btn btn-success" style="float:left;margin-right:5px;"
           asp-controller="Admin"
           asp-action="AccControl">
            Khách hàng
        </a>
        <a class="btn btn-success" style="float:left;margin-right:5px;"
           asp-controller="Admin"
           asp-action="BookControl">
            Sản phẩm
        </a>

        <a class="btn btn-success" style="float:left;margin-right:5px"
           asp-controller="Admin"
           asp-action="BillControl">
            Đơn hàng
        </a>
    </div>

    <div class="col-md-12">
        <div style="background: #f2f2f2; padding: 10px; margin-bottom: 10px; border-radius: 10px;">
            <div class="d-flex justify-content-between">
                <div style="margin-left: 25px;" class=" col-5">
                    <div class="form-group mt-2 d-flex" style="align-items: center">
                        <label style="width: 130px" for="name">Email:</label>
                        <input type="text" class="form-control" id="name" name="name" />
                    </div>
                    <div class="form-group mt-2 d-flex" style="align-items: center">
                        <label style="width: 130px">Tên KH:</label>
                        <input type="text" class="form-control" id="name" name="name" />
                    </div>
                    <div class="form-group mt-2 d-flex" style="align-items: center">
                        <label style="width: 130px;" for="name">Loại KH:</label>
                        <input type="text" class="form-control" id="name" name="name" />
                    </div>
                </div>
                <div style="margin-right: 25px;" class=" d-flex flex-column align-items-center justify-content-center">
                    <div>
                        <a asp-route-id="" style="height: 40px; width: 200px" class="btn btn-success mb-2"
                           method="get"
                           asp-controller="Cart"
                           asp-action="InfoOrder"
                           asp-route-IDBook=""
                           asp-route-number=""
                           id="showMessageBtn">Tìm kiếm</a>
                    </div>
                    <div>
                        <a method="get" style="height: 60px; width: 200px" class="btn btn-primary d-flex flex-column align-items-center justify-content-center"
                           method="get"
                           asp-controller="Cart"
                           asp-action="InfoOrder"
                           asp-route-idItem=""
                           id="showMessageBtn">
                            <p class="mb-0">Quảng cáo</p>
                        </a>
                    </div>
                </div>

            </div>
        </div>
    </div>

    <table id="example" class="table table-striped table-bordered" cellspacing="0" width="100%">
        <thead>
            <tr class="text-center">
                <th>Email</th>
                <th>Tên người dùng</th>
                <th>Số điện thoại</th>
                <th>Xác thực email</th>
                <th>Thao tác</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>@item.Email</td>
                    <td>@item.UserName</td>
                    <td>@item.PhoneNumberConfirmed</td>
                    @if (item.EmailConfirmed == true)
                    {
                        <td>Đã xác thực</td>
                    }
                    else
                    {
                        <td>Chưa xác thực</td>
                    }
                    <td>
                        <button type="button" class="col btn btn-primary btn-xs dt-edit" style="margin-right:16px;">
                            Quảng cáo
                        </button>
                        <button type="button" class="col-4 btn btn-danger btn-xs dt-delete">
                            Khóa 
                        </button>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>
<!-- Modal -->
<div id="myModal" class="modal fade" role="dialog">
    <div class="modal-dialog">

        <!-- Modal content-->
        <div class="modal-content">
            <div class="modal-header">
                <button type="button" class="close" data-dismiss="modal">&times;</button>
                <h4 class="modal-title">Row information</h4>
            </div>
            <div class="modal-body">
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-default" data-dismiss="modal">Close</button>
            </div>
        </div>

    </div>
</div>

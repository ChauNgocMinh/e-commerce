@model E_Commerce.Models.BookModel

<style>
    .container {
        padding: 20px;
    }

    .product-details {
      display: flex;
      align-items: center;
      box-shadow: 0px 0px 10px rgba(0, 0, 0, 0.3);
      padding: 20px;
    }

    .product-image {
      flex: 1;
      text-align: center;
    }

    .product-image img {
      max-width: 80%;
      max-height: 300px;
    }

    .product-info {
      flex: 1;
      padding: 20px;
      border: 1px solid #ccc;
    }

    .product-info h2 {
      font-size: 24px;
      margin-bottom: 5px;
    }

    .product-info p {
      font-size: 16px;
      margin-bottom: 10px;
    }

    .buttons {
      display: flex;
      justify-content: center;
      margin-top: 20px;
    }

    .buttons button {
      margin: 5px;
      padding: 10px 20px;
      font-size: 16px;
    }
</style>

<div class="container">
    <div class="row">
        <div class="container">`
            <div class="product-details">
                <div class="product-image">
                    <img src="@Model.Picture" alt="@Model.Namebook">
                </div>
                <div class="col-md-6 product-info">
                    <h3>@Model.Namebook</h3>
                    <p>Nhà xuất bản: @Model.PublishingCompany</p>
                    <p>Thể loại: @Model.Category</p>
					<p>(0 đánh giá) <a> Click để đánh giá</a></p>
                    <p>Giá: @Model.Price VNĐ</p>
                    <p>Vận chuyển: Giảm 30% phí vận chuyển bởi Nhất Tín Express (NTX)</p>
					<p>Tình trạng: <i>Còn hàng</i></p>
                    <div class="quantity-input">
                        <label for="quantity">Số lượng:</label>
                        <input type="number" id="quantity" name="quantity" min="1" value="1">
                    </div>

                  
                    <div class="buttons">
                        <a asp-route-id="@Model.Id" class="btn btn-success col-7">Buy</a>

                        <a method="get"
                            asp-controller="Cart"
                            asp-action="AddItem"
                            asp-route-ID="@Model.Id"
                            asp-route-number="1"
                            class="btn btn-primary float-end col-3"
                            id="showMessageBtn">

                            <i class="fas fa-cart-plus"></i>
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>  
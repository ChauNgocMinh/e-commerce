@model List<E_Commerce.Models.BookModel>

<p>
    <a asp-action="AddBook">Create New</a>
</p>

<style>
    .product-card {
        border: 1px solid #ccc;
        padding: 15px;
        margin-bottom: 20px;
    }

    .product-image {
        max-width: 200px;
        height: 250px;
    }

</style>


<div class="container">
    <div class="row">
        @foreach (var item in Model)
        {
            <div class="col-lg-3 col-md-4 col-sm-6">
                <div class="product-card">
                    <div class="row justify-content-center align-items-center">
                        <img src="@Html.DisplayFor(modelItem => item.Picture)" class="product-image card-img-top" alt="Product Image">
                    </div>
                    <div class="card-body">
                        <h5 class="card-title"> @Html.DisplayFor(modelItem => item.Namebook)</h5>
                        <p class="card-text"> @Html.DisplayFor(modelItem => item.Status)</p>
                        <p class="card-text"> @Html.DisplayFor(modelItem => item.Price)</p>
                        <div class="row d-flex justify-content-between" style="width: 100%">
                            <a href="#" class="btn btn-success col-7">Buy</a>
                            <a href="#" class="btn btn-primary float-end col-3"><i class="fas fa-cart-plus"></i></a>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
</div>
